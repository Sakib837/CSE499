# Environment Configuration - Backend
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development
PORT=5000

# Database - MongoDB Atlas
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/fuel_dispensing?retryWrites=true&w=majority
MONGO_DB_NAME=fuel_dispensing

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long_!!
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_chars_!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Google Gemini API
GEMINI_API_KEY=your_google_gemini_api_key_here

# Socket.io Configuration
SOCKET_IO_ORIGIN=http://localhost:3000
SOCKET_IO_TRANSPORTS=websocket,polling

# Email Service (Optional - for password reset)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password

# Redis (Optional - for token blacklist)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Machine API Authentication
MACHINE_API_KEY_SALT=machine_api_key_salt_minimum_32_chars

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Monitoring
ENABLE_METRICS=true
ENABLE_HEALTH_CHECK=true
